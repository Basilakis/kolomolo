# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Extraction wants accuracy; planning/answering can use a cheaper tier.
EXTRACTION_MODEL=claude-opus-4-8
AGENT_MODEL=claude-sonnet-4-6

# --- Neo4j (must match docker-compose.yml) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sleepmedcorp
NEO4J_DATABASE=neo4j

# --- Paths ---
DATA_ZIP=data/cpap-datasheets-and-manuals.zip
DATA_DIR=data/corpus          # where the zip is unpacked

# --- Baseline ---
CHROMA_DIR=.chroma
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
